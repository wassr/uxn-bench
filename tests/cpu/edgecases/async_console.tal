|00 @System/vector $2 &expansion $2 &wst $1 &rst $1 &metadata $2 &r $2 &g $2 &b $2 &debug $1 &state $1
|10 @Console/vector $2 &read $1 &pad $4 &type $1 &write $1 &error $1

|0100
@test
    ;on-console .Console/vector DEO2
    BRK

@on-console
    .Console/read DEI
    DUP #04 EQU ,&done JCN
    
    ;global LDA2 INC2 ;global STA2
    
    ;local LDA2 INC2 ;local STA2
    BRK

&done
    POP
    ;local LDA2 ;global LDA2 EQU2 ,&ok JCN
    #81 #0f DEO BRK
&ok
    #80 #0f DEO BRK

@global $2
@local $2
